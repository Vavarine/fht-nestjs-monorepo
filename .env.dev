NODE_ENV=development

HOST=localhost

BASE_URL=http://localhost:3000

API_PORT=3000
VIDEO_PROCESSOR_PORT=3001
USER_NOTIFIER_PORT=3002

# Database configuration
POSTGRES_USER=fiapdev
POSTGRES_PASSWORD=fiap2026dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fiap_hackathon

DATABASE_URL="postgresql://fiapdev:fiap2026dev@localhost:5432/fiap_hackathon?schema=public"
REDIS_URL="redis://localhost:6379"

# RabbitMQ configuration
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

RABBITMQ_URL="amqp://guest:guest@localhost:5672"
VIDEO_PROCESSING_SERVICE_QUEUE="video_processing_queue"
USER_NOTIFIER_SERVICE_QUEUE="user_notifier_queue"
RABBITMQ_PREFETCH_COUNT=1
RABBITMQ_REQUEUE_ON_ERROR=false

UPLOADS_PATH=/apps/api/uploads

# RustFS / S3 configuration
FS_ACCESS_KEY_ID=rustfsadmin
FS_SECRET_ACCESS_KEY=rustfsadmin
FS_ENDPOINT_URL=http://localhost:9000
FS_ENDPOINT_URL_PUBLIC=http://localhost:9000
FS_BUCKET_NAME=fht-videos-dev
