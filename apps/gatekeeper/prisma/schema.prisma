datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

model Customer {
  id        String   @id // Cognito sub (UUID v4)
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
}
