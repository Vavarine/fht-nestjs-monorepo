datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

model VideoProcessingJob {
  id            String   @id @default(uuid())
  videoFile     String?
  processedFile String?
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String
}
