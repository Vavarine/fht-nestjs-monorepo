{
  "monorepo": true,
  "root": "apps/api",
  "sourceRoot": "apps/api/src",
  "compilerOptions": {
    "webpack": true,
    "tsConfigPath": "apps/api/tsconfig.app.json"
  },
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "file-manager": {
      "type": "library",
      "root": "libs/file-manager",
      "entryFile": "index",
      "sourceRoot": "libs/file-manager/src",
      "compilerOptions": {
        "tsConfigPath": "libs/file-manager/tsconfig.lib.json"
      }
    },
    "video-processor": {
      "type": "application",
      "root": "apps/video-processor",
      "entryFile": "main",
      "sourceRoot": "apps/video-processor/src",
      "compilerOptions": {
        "tsConfigPath": "apps/video-processor/tsconfig.app.json"
      }
    }
  }
}